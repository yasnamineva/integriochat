// Supabase (PostgreSQL) with pgvector extension
// RLS policies should be applied separately via Supabase SQL editor
// to enforce tenantId at the database level as a safety net.
// Prisma middleware (see src/middleware.ts) is the primary isolation mechanism.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector", schema: "extensions")]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Plan {
  FREE
  HOBBY
  STANDARD
  PRO
  ENTERPRISE
  USAGE
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String   @unique
  // allowedDomains moved to Chatbot — each bot controls its own embed CORS list
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users              User[]
  chatbots           Chatbot[]
  embeddingDocuments EmbeddingDocument[]
  demoLinks          DemoLink[]
  subscriptions      Subscription[]
  messages           Message[]
  usageLogs          UsageLog[]
  customQAs          CustomQA[]
  webhooks           Webhook[]

  @@map("tenants")
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  email     String   @unique
  password  String   // bcrypt hash
  role      Role     @default(CLIENT)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model Chatbot {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  name          String
  systemPrompt  String    @db.Text
  tone          String    @default("professional")
  leadCapture   Boolean   @default(false)
  isActive      Boolean   @default(true)
  // Website training
  websiteUrl    String?
  scrapeStatus  String    @default("idle") // idle | scraping | done | error
  lastScrapedAt DateTime?
  autoRetrain   Boolean   @default(false)
  // AI configuration
  aiModel       String    @default("gpt-4o-mini")
  temperature   Float     @default(0.7)
  maxTokens     Int       @default(500)
  fallbackMsg   String    @default("I'm sorry, I don't have enough information to answer that. Please contact our support team for help.") @db.Text
  // White label / appearance
  chatTitle     String?
  chatAvatar    String?
  themeColor    String    @default("#6366f1")
  widgetPosition String   @default("bottom-right") // "bottom-right" | "bottom-left"
  widgetTheme   String    @default("light")         // "light" | "dark"
  initialMessage String   @default("Hi! How can I help you today?")
  suggestedQs   String[]
  // CORS: restrict which origins can embed this chatbot's widget
  allowedDomains String[] // e.g. ["example.com", "*.acme.io"] — empty = allow all
  // API access
  apiKey        String    @unique @default(dbgenerated("concat('cb_', replace(gen_random_uuid()::text, '-', ''))"))
  // Web search (Tavily) — let the bot search the internet in real time
  webSearchEnabled Boolean @default(false)
  // Per-chatbot spending caps (USAGE plan) — null = no cap
  // monthlyMessageLimit: max user messages per calendar month for this chatbot
  // monthlySpendLimitCents: max billing charge (at 95% margin rate) in USD cents per month
  monthlyMessageLimit    Int?
  monthlySpendLimitCents Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  embeddingDocuments EmbeddingDocument[]
  demoLinks          DemoLink[]
  messages           Message[]
  usageLogs          UsageLog[]
  customQAs          CustomQA[]
  webhooks           Webhook[]

  @@index([tenantId])
  @@map("chatbots")
}

model CustomQA {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  chatbotId String   @db.Uuid
  question  String   @db.Text
  answer    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([chatbotId])
  @@map("custom_qas")
}

model EmbeddingDocument {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  chatbotId   String   @db.Uuid
  content     String   @db.Text
  // pgvector column — text-embedding-3-small produces 1536-dimensional vectors
  embedding   Unsupported("vector(1536)")?
  sourceUrl   String
  contentHash String   // SHA-256 of content; skip re-embedding if unchanged
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([chatbotId])
  @@map("embedding_documents")
}

model DemoLink {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  chatbotId String   @db.Uuid
  token     String   @unique @default(dbgenerated("gen_random_uuid()"))
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
  @@map("demo_links")
}

model Subscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String             @db.Uuid
  stripeCustomerId     String?
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  stripeItemId         String?
  stripeUsageItemId    String?
  status               SubscriptionStatus @default(TRIALING)
  plan                 Plan               @default(FREE)
  billingPeriod        BillingPeriod      @default(MONTHLY)
  removeBranding       Boolean            @default(false)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscriptions")
}

model Message {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  chatbotId String   @db.Uuid
  sessionId String   // groups messages in a conversation
  role      String   // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([chatbotId])
  @@index([sessionId])
  @@map("messages")
}

model UsageLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  chatbotId  String   @db.Uuid
  tokensUsed Int      @default(0)
  costUsd    Decimal  @default(0) @db.Decimal(10, 6)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([chatbotId])
  @@map("usage_logs")
}

model Webhook {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  chatbotId String   @db.Uuid
  name      String
  url       String
  events    String[] // e.g. ["message.completed", "conversation.started", "lead.captured"]
  isActive  Boolean  @default(true)
  secret    String   @default(dbgenerated("concat('wh_', replace(gen_random_uuid()::text, '-', ''))"))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chatbot Chatbot @relation(fields: [chatbotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([chatbotId])
  @@map("webhooks")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}
